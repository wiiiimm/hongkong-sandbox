# We work across multiple devices and sandboxes, so ALL project files
# (app, scripts, docs, references, data, meshes) are committed.
# Only truly local / regeneratable dev cruft is ignored below.

# === OS / editor cruft ===
.DS_Store
**/.DS_Store
*.swp
Thumbs.db

# === Python (regeneratable) ===
__pycache__/
*.pyc
venv/
.venv/

# === Node / build output (regeneratable) ===
node_modules/
dist/
.vercel/

# === Secrets / local env (must stay local) ===
.env
.env.*
!.env.example

# wrangler local cache/state (never commit — may hold account info)
.wrangler/

# HKS-84 sky data prep: the 53 MB Hipparcos main catalogue is fetched on
# demand by source-scripts/hk-sky/build_hk_sky.mjs — too big to commit;
# the smaller cached sources (BSC5, constellationship.fab) ARE committed.
source-scripts/hk-sky/cache/hip_main.dat
